flowchart TB
    USERS["Milhoes de usuarios"]

    subgraph LB["Load Balancer"]
        NGINX["Nginx / ALB"]
    end

    subgraph INSTANCES["Go API · stateless, N instancias"]
        direction LR
        GO1["Go API 1"]
        GO2["Go API 2"]
        GO3["Go API 3"]
        GON["Go API N..."]
    end

    subgraph REDIS_C["Redis Cluster"]
        direction LR
        R1["Primary\nINCR + Cache"]
        R2["Replica 1"]
        R3["Replica 2"]
    end

    subgraph PG_C["PostgreSQL"]
        direction LR
        PG_P["Primary\n(escrita)"]
        PG_R1["Replica 1\n(leitura)"]
        PG_R2["Replica 2\n(leitura)"]
    end

    USERS --> NGINX
    NGINX --> GO1
    NGINX --> GO2
    NGINX --> GO3
    NGINX --> GON

    GO1 & GO2 & GO3 & GON --> R1
    R1 --> R2
    R1 --> R3

    GO1 & GO2 & GO3 & GON -->|"escrita"| PG_P
    GO1 & GO2 & GO3 & GON -->|"leitura"| PG_R1
    GO1 & GO2 & GO3 & GON -->|"leitura"| PG_R2
    PG_P -->|"replicacao"| PG_R1
    PG_P -->|"replicacao"| PG_R2

