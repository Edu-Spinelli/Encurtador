flowchart TB
    subgraph CLIENT["Frontend · Next.js / Vercel"]
        UI["Interface do usuario"]
    end

    subgraph API["Go API · Railway"]
        direction TB
        SHORTEN["POST /shorten\n(Command)"]
        REDIRECT["GET /{code}\n(Query)"]
        STATS["GET /stats"]
    end

    subgraph REDIS_LAYER["Redis"]
        INCR["INCR\nID atomico"]
        CACHE["Cache\nTTL 24h"]
    end

    subgraph ENCODE["Encoding"]
        HASH["HashIDs\nBase62 + Salt + Pepper"]
    end

    subgraph DB["PostgreSQL"]
        PG[("urls\nshort_code | long_url | created_at")]
    end

    UI -->|"POST /shorten"| SHORTEN
    UI -->|"GET /{code}"| REDIRECT
    UI -->|"GET /stats"| STATS

    SHORTEN --> INCR
    INCR --> HASH
    HASH -->|"salvar"| PG

    REDIRECT --> CACHE
    CACHE -->|"hit"| UI
    CACHE -->|"miss"| PG
    PG -->|"302 redirect"| UI

    style CLIENT fill:#ede9fe,stroke:#7c3aed,stroke-width:2px,color:#18181b
    style API fill:#f0fdf4,stroke:#22c55e,stroke-width:2px,color:#18181b
    style REDIS_LAYER fill:#fef2f2,stroke:#ef4444,stroke-width:2px,color:#18181b
    style ENCODE fill:#fefce8,stroke:#eab308,stroke-width:2px,color:#18181b
    style DB fill:#eff6ff,stroke:#3b82f6,stroke-width:2px,color:#18181b
