SERVER_PORT=:8080
BASE_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Local: redis://127.0.0.1:6379
# Upstash: redis://default:TOKEN@HOST:PORT
REDIS_URL=redis://127.0.0.1:6379
REDIS_START_OFFSET=14000000

# Local: postgres://postgres:postgres@127.0.0.1:5432/encurtador?sslmode=disable
# Supabase: postgres://postgres.XXX:PASSWORD@HOST:5432/postgres
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/encurtador?sslmode=disable

HASH_SALT=troque-por-um-salt-seguro
HASH_PEPPER=troque-por-um-pepper-seguro
HASH_MIN_LENGTH=6
